{
  "name": "@smplcty/oidc",
  "version": "0.1.1",
  "description": "Tiny TypeScript helper for looking up per-tenant OIDC (and other) auth-domain configuration from a Postgres auth_domains table.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mabulu-inc/simplicity-oidc.git"
  },
  "homepage": "https://github.com/mabulu-inc/simplicity-oidc#readme",
  "bugs": {
    "url": "https://github.com/mabulu-inc/simplicity-oidc/issues"
  },
  "keywords": [
    "oidc",
    "openid-connect",
    "saml",
    "sso",
    "multi-tenant",
    "postgres"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smplcty/schema-flow": "^0.3.7",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "pg": "^8.20.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
